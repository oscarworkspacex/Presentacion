# ==============================================
# PRESENTON BACKEND - Variables de Entorno (PLANTILLA)
# ==============================================
# IMPORTANTE: Copia este archivo a .env y configura tus valores reales

# ----------------------------------------------
# AUTENTICACIÓN DEL SISTEMA
# ----------------------------------------------
# Credenciales para acceder al sistema
# IMPORTANTE: Cambia estas credenciales en producción
AUTH_USERNAME=zucaritas
AUTH_PASSWORD=g3st24mWork5

# Secret key para JWT (genera una clave segura en producción)
# Genera una con: openssl rand -hex 32
# Si dejas vacío, se generará una automáticamente (NO recomendado en producción)
JWT_SECRET_KEY=

# Tiempo de expiración del token JWT en minutos
# Default: 1440 minutos = 24 horas
JWT_EXPIRE_MINUTES=1440

# ----------------------------------------------
# CONFIGURACIÓN DE LLM PROVIDERS
# ----------------------------------------------
# Opciones: ollama (default), openai, google, anthropic, custom
LLM=ollama

# OpenAI Configuration
# Obtén tu API key en: https://platform.openai.com/api-keys
OPENAI_API_KEY=tu-api-key-aqui
OPENAI_MODEL=gpt-4o

# Google Gemini Configuration
# Obtén tu API key en: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=tu-api-key-aqui
GOOGLE_MODEL=gemini-2.0-flash-exp

# Anthropic Claude Configuration
# Obtén tu API key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=tu-api-key-aqui
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama Configuration (Local AI - No requiere API key)
# URL del servidor Ollama local
OLLAMA_URL=http://localhost:11434
# Modelo a usar (debe estar descargado con 'ollama pull')
OLLAMA_MODEL=qwen2.5:0.5b

# Custom LLM Configuration (para endpoints personalizados)
CUSTOM_LLM_URL=https://tu-endpoint-personalizado.com/v1
CUSTOM_LLM_API_KEY=tu-api-key-aqui
CUSTOM_MODEL=tu-modelo

# ----------------------------------------------
# SERVICIOS DE IMÁGENES
# ----------------------------------------------
# Opciones: pexels, pixabay, gemini_flash, dall-e-3
# dall-e-3 usa GPT Image internamente (OpenAI retiró DALL-E 3 en mayo 2026)
# Dejar vacío para deshabilitar
IMAGE_PROVIDER=

# Modelos de generación de imágenes (opcionales)
# OpenAI: gpt-image-1.5 (default), gpt-image-1-mini, gpt-image-2
OPENAI_IMAGE_MODEL=gpt-image-1.5
# Google: gemini-3.1-flash-image (default)
GOOGLE_IMAGE_MODEL=gemini-3.1-flash-image
# Máximo de generaciones de imagen simultáneas (default: 2)
IMAGE_GENERATION_MAX_CONCURRENT=2

# API Keys para providers de imágenes
# Pexels: https://www.pexels.com/api/
PEXELS_API_KEY=tu-api-key-aqui
# Pixabay: https://pixabay.com/api/docs/
PIXABAY_API_KEY=tu-api-key-aqui

# ----------------------------------------------
# CONFIGURACIÓN AVANZADA DE LLM
# ----------------------------------------------
# Permitir cambio de API keys desde la interfaz de usuario
CAN_CHANGE_KEYS=true

# Habilitar tool calls para structured output (solo custom LLM)
TOOL_CALLS=false

# Deshabilitar thinking (razonamiento visible en respuestas)
DISABLE_THINKING=false

# Habilitar razonamiento extendido (modelos que lo soporten)
EXTENDED_REASONING=false

# Habilitar web grounding (búsqueda web en tiempo real)
WEB_GROUNDING=false

# ----------------------------------------------
# BASE DE DATOS
# ----------------------------------------------
# Base de datos principal
# 
# Para MySQL (recomendado para producción):
#   1. Crea la base de datos: CREATE DATABASE nombre_bd CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
#   2. Desde Docker: usa la IP del gateway (generalmente 172.23.0.1)
#   3. Formato: mysql+aiomysql://usuario:contraseña@172.23.0.1:3306/nombre_bd
# 
# Para SQLite (desarrollo):
#   Dejar vacío para usar SQLite por defecto en /app_data
#   O especificar: sqlite:///path/to/db.db
# 
# Otras opciones:
#   PostgreSQL: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=mysql+aiomysql://root:tu-contraseña@172.23.0.1:3306/tu-bd

# Base de datos del contenedor (para estado interno)
# NO MODIFICAR a menos que sepas lo que haces
CONTAINER_DB_URL=sqlite+aiosqlite:////app/container.db

# ----------------------------------------------
# URLS Y PUERTOS INTERNOS
# ----------------------------------------------
# NOTA: Estos valores son para comunicación interna entre servicios
# Solo modificar si has cambiado la arquitectura por defecto

# Puerto del servidor MCP (Model Context Protocol)
MCP_PORT=8001

# URL interna de FastAPI (para comunicación desde MCP server)
FASTAPI_INTERNAL_URL=http://127.0.0.1:8000

# URL interna de Next.js (para obtener layouts desde FastAPI)
NEXTJS_INTERNAL_URL=http://localhost:3000

# Timeout para cliente HTTP interno (en segundos)
HTTP_CLIENT_TIMEOUT=60.0

# ----------------------------------------------
# DIRECTORIOS
# ----------------------------------------------
# Directorio para datos persistentes (presentaciones, imágenes, exports)
# NO MODIFICAR si usas Docker
APP_DATA_DIRECTORY=/app_data

# Directorio temporal para archivos temporales
TEMP_DIRECTORY=/tmp/presenton

# ----------------------------------------------
# PRIVACIDAD Y TELEMETRÍA
# ----------------------------------------------
# Deshabilitar tracking anónimo de uso
DISABLE_ANONYMOUS_TRACKING=false
